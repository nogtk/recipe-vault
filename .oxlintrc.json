{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2024": true
  },
  "ignorePatterns": ["node_modules/**", ".wrangler/**", ".playwright-mcp/**", "dist/**"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "eslint/no-await-in-loop": "off"
  }
}
